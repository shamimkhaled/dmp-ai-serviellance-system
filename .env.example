# ─────────────────────────────────────────────
# Police AI – Deployment environment overrides
# Copy to `.env` (gitignored) and edit for your server.
# ─────────────────────────────────────────────

# Public IP or hostname of THIS server, reachable from operator browsers.
# Used for:
#   - MediaMTX WebRTC/WHEP ICE candidates (webrtcAdditionalHosts)
#   - Dashboard VITE_* URLs (alert-service, video-ingest, traffic-ai, MediaMTX WHEP/HLS)
#   - video-ingest WHEP/HLS/RTSP base URLs returned to the dashboard
#
# Local dev (default if unset): localhost / 127.0.0.1
# VM deployment example:
HOST_IP=172.0.3.0
HOST_IP=localhost
